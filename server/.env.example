# Coach Task Tracker — Environment Configuration

# Authentication
JWT_SECRET=your-secret-key-here-must-be-at-least-32-characters-long

# Groq API (Phase 7: Multi-Agent Coaching Insights)
# Get free key (no credit card required): https://console.groq.com
# Model: llama-3.3-70b-versatile
# Free tier: 30 requests/minute, 6,000 tokens/minute
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# Coaching Insights Feature Toggle
# Set to 'true' to enable Phase 7 multi-agent coaching insights
# When enabled: coaches get AI-powered behavior analysis notifications
# When disabled: feature is silently skipped (graceful degradation)
COACHING_INSIGHTS_ENABLED=true

# Database (default: SQLite local file)
# DATABASE_URL=sqlite:./tracker.db

# Node Environment
# NODE_ENV=development
